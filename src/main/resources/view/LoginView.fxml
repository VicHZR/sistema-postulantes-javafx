<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LoginController"
      spacing="15" alignment="CENTER"
      prefWidth="350" prefHeight="300"
      style="-fx-background-color: white;">
    
    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <Label text="Inicio de Sesión"
           style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill: #1976d2;"/>

    <VBox spacing="5">
        <Label text="Usuario:"/>
        <TextField fx:id="txtUsuario" promptText="Ingrese su usuario" prefHeight="35"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Contraseña:"/>
        <PasswordField fx:id="txtPassword" promptText="••••••••" prefHeight="35"/>
    </VBox>

    <Button text="Ingresar al Sistema"
            onAction="#login"
            maxWidth="Infinity"
            prefHeight="40"
            style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Label fx:id="lblMensaje"
           style="-fx-text-fill:red; -fx-font-size: 12px;"
           wrapText="true"/>
</VBox>
